{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "shadow-cljs",
        "severity": "error",
        "pattern": {
          "regexp": "^--\\s+(.+)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "shadow-cljs - (?:compiling|watching)",
          "endsPattern": "shadow-cljs - (?:Build completed|nREPL server)"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
