{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"calva.autoStartRepl": true,
		"calva.replConnectSequences": [
			{
				"name": "Mini Clojure Project",
				"projectRootPath": [
					"."
				],
				"cljsType": "none",
				"projectType": "deps.edn",
				"replSessionNames": {
					"primary": "mini-clj"
				},
				"replSessionFilePatterns": {
					"primary": {
						"always-claim": [
							"**/*.clj"
						]
					}
				},
				"menuSelections": {
					"cljAliases": [
						"test"
					]
				}
			},
			{
				"name": "Shadow CLJS (browser + tui)",
				"autoSelectForConnect": true,
				"projectRootPath": [
					"."
				],
				"cljsType": "shadow-cljs",
				"projectType": "shadow-cljs",
				"replSessionNames": {
					"primary": "shadow-clj",
					"secondary": "shadow-cljs"
				},
				"replSessionFilePatterns": {
					"primary": {
						"always-claim": [
							"deps.edn",
							"shadow-cljs.edn"
						]
					},
					"secondary": {
						"always-claim": [
							"**/app.cljs",
							"**/tui.cljs"
						]
					}
				},
				"menuSelections": {
					"cljAliases": [
						"dev"
					],
					"cljsLaunchBuilds": [
						":app",
						":tui"
					],
					"cljsDefaultBuild": ":app"
				}
			}
		],
		"calva.autoOpenInspector": false,
		// "calva-backseat-driver.autoStartMCPServer": true,
		// "calva-backseat-driver.mcpSocketServerPort": 0
	},
}