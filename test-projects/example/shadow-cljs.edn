{:deps true
 :dev-http {8780 "resources/public"}
 :builds
 {:app {:target :browser
        :output-dir "resources/public/js"
        :asset-path "/js"
        :modules {:main {:init-fn mini.app/init}}
        :devtools {:after-load mini.app/reload}}
  :tui {:target :node-script
        :main mini.tui/main
        :output-to "out/mini-tui.js"
        :devtools {:after-load mini.tui/reload}}}}
