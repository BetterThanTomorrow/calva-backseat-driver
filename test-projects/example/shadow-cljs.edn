{:deps true
 :dev-http {8780 "resources/public"}
 :builds
 {:app {:target :browser
        :output-dir "resources/public/js"
        :asset-path "/js"
        :modules {:main {:init-fn mini.app/init}}
        :devtools {:after-load mini.app/reload}}
  :server {:target :node-script
           :main mini.server/main
           :output-to "out/mini-server.js"
           :devtools {:after-load mini.server/reload}}}}
